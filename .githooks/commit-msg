#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:-}"
if [[ -z "$msg_file" || ! -f "$msg_file" ]]; then
  echo "commit-msg hook error: missing commit message file" >&2
  exit 1
fi

header="$(head -n1 "$msg_file" | tr -d '\r')"

# Allow merge/revert commits generated by git.
if [[ "$header" =~ ^Merge\  ]] || [[ "$header" =~ ^Revert\  ]]; then
  exit 0
fi

# Allow autosquash helper commits.
if [[ "$header" =~ ^(fixup|squash)!\  ]]; then
  exit 0
fi

# Conventional Commits v1.0.0
# <type>[optional scope][!]: <description>
regex='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if [[ ! "$header" =~ $regex ]]; then
  cat >&2 <<'EOF'
✗ Invalid commit message format.

Use Conventional Commits:
  <type>[optional scope][!]: <description>

Examples:
  feat(scraper): add single-article e2e flag
  fix(repository): handle sqlite duplicate insert
  chore: update docs

Reference: https://www.conventionalcommits.org/en/v1.0.0/
EOF
  exit 1
fi
